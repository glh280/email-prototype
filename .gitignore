# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# env
.env
.env.local
.env*.local

# drizzle studio temp
.drizzle/

# playwright
test-results/
playwright-report/
.playwright-uat/

# skills CLI — local skill install directory (symlinked from .claude/skills)
# skills-lock.json IS committed for reproducibility
.agents/
.claude/skills/

# ClickUp import — discovery dumps and sample payloads may contain PII (task
# titles, assignee emails, custom field values). The seed/import scripts
# themselves are committed; the data they produce is not.
db/seed/.clickup-*.json
